apiVersion: serving.kserve.io/v1alpha1
kind: ServingRuntime
metadata:
  annotations:
    opendatahub.io/template-display-name: ServingRuntime for vLLM | RHAIIS
  labels:
    opendatahub.io/dashboard: "true"
  name: {{ args.deployment_name }}
  namespace: {{ args.namespace }}
spec:
{%- if args.image_pull_secret %}
  imagePullSecrets:
    - name: {{ args.image_pull_secret }}
{%- endif %}
  builtInAdapter:
    modelLoadingTimeoutMillis: 300000
  multiModel: false
  supportedModelFormats:
    - autoSelect: true
      name: vLLM
  containers:
    - name: kserve-container
      image: "{{ args.vllm_image }}"
      command:
        - python3
        - -m
        - vllm.entrypoints.openai.api_server
      args:
{%- if args.storage_source == "hf" %}
        - --model={{ args.model_id }}
{%- else %}
        - --model=/mnt/models
        - --served-model-name={{ args.model_id }}
{%- endif %}
        - --port=8080
{%- for key, val in (args.vllm_args or {}).items() %}
  {%- if val is boolean %}
    {%- if val %}
        - --{{ key }}
    {%- endif %}
  {%- else %}
        - --{{ key }}={{ val }}
  {%- endif %}
{%- endfor %}
      env:
{%- if args.storage_source == "hf" %}
        - name: HF_HUB_OFFLINE
          value: "0"
        - name: HOME
          value: /mnt/models
        - name: HF_HOME
          value: /mnt/models
        - name: VLLM_CACHE_DIR
          value: /mnt/models/.cache/vllm
        - name: HF_DATASETS_CACHE
          value: /mnt/models/.cache/huggingface/datasets
        - name: HF_TOKEN
          valueFrom:
            secretKeyRef:
              name: storage-config
              key: HF_TOKEN
{%- endif %}
{%- for env_item in ctx.env_vars_list %}
        - name: {{ env_item.name }}
          value: "{{ env_item.value }}"
{%- endfor %}
      ports:
        - containerPort: 8080
          protocol: TCP
{%- if ctx.gpu_count > 1 %}
      volumeMounts:
        - name: shared-memory
          mountPath: /dev/shm
  volumes:
    - name: shared-memory
      emptyDir:
        medium: Memory
        sizeLimit: 8Gi
{%- endif %}
---
apiVersion: serving.kserve.io/v1beta1
kind: InferenceService
metadata:
  annotations:
    serving.kserve.io/deploymentMode: RawDeployment
    serving.kserve.io/enable-prometheus-scraping: "true"
    storage.kserve.io/readonly: "false"
    prometheus.io/scrape: "true"
    prometheus.io/path: /metrics
    prometheus.io/port: "8080"
  labels:
    opendatahub.io/dashboard: "true"
  name: {{ args.deployment_name }}
  namespace: {{ args.namespace }}
spec:
  predictor:
    minReplicas: {{ args.replicas }}
    maxReplicas: {{ args.replicas }}
    model:
      modelFormat:
        name: vLLM
      runtime: {{ args.deployment_name }}
      resources:
{%- if args.accelerator == "nvidia" %}
        limits:
          nvidia.com/gpu: "{{ ctx.gpu_count }}"
        requests:
          nvidia.com/gpu: "{{ ctx.gpu_count }}"
{%- elif args.accelerator == "amd" %}
        limits:
          amd.com/gpu: "{{ ctx.gpu_count }}"
        requests:
          amd.com/gpu: "{{ ctx.gpu_count }}"
{%- endif %}
          cpu: "{{ args.cpu_request }}"
          memory: "{{ args.memory_request }}"
{%- if args.storage_source == "hf" and ctx.use_pvc %}
      storageUri: pvc://{{ ctx.pvc_name }}/
{%- elif args.storage_source != "hf" %}
      storageUri: {{ args.storage_source }}://{{ args.model_id }}
{%- endif %}
{%- if args.service_account_name %}
    serviceAccountName: {{ args.service_account_name }}
{%- endif %}
