apiVersion: serving.kserve.io/v1alpha1
kind: ServingRuntime
metadata:
  annotations:
    opendatahub.io/template-display-name: ServingRuntime for vLLM | RHAIIS
  labels:
    opendatahub.io/dashboard: "true"
  name: {{ args.deployment_name }}
  namespace: {{ args.namespace }}
spec:
{%- if args.image_pull_secret %}
  imagePullSecrets:
    - name: {{ args.image_pull_secret }}
{%- endif %}
  builtInAdapter:
    modelLoadingTimeoutMillis: 300000
  multiModel: false
  supportedModelFormats:
    - autoSelect: true
      name: vLLM
  containers:
    - name: kserve-container
      image: "{{ args.vllm_image }}"
      command:
        - python3
        - -m
        - vllm.entrypoints.openai.api_server
      args:
{%- if args.storage_source == "hf" %}
        - --model={{ args.model_id }}
{%- else %}
        - --model=/mnt/models
        - --served-model-name={{ args.model_id }}
{%- endif %}
        - --port=8080
{%- for key, val in (args.vllm_args or {}).items() %}
  {%- if val is boolean %}
    {%- if val %}
        - --{{ key }}
    {%- endif %}
  {%- else %}
        - --{{ key }}={{ val }}
  {%- endif %}
{%- endfor %}
      env:
{%- if args.storage_source == "hf" %}
        - name: HF_HUB_OFFLINE
          value: "0"
        - name: HOME
          value: /mnt/models
        - name: HF_HOME
          value: /mnt/models
        - name: VLLM_CACHE_DIR
          value: /mnt/models/.cache/vllm
        - name: HF_DATASETS_CACHE
          value: /mnt/models/.cache/huggingface/datasets
        - name: HF_TOKEN
          valueFrom:
            secretKeyRef:
              name: storage-config
              key: HF_TOKEN
{%- endif %}
{%- for env_item in ctx.env_vars_list %}
        - name: {{ env_item.name }}
          value: "{{ env_item.value }}"
{%- endfor %}
      ports:
        - containerPort: 8080
          protocol: TCP
{%- if ctx.gpu_count > 1 %}
      volumeMounts:
        - name: shared-memory
          mountPath: /dev/shm
  volumes:
    - name: shared-memory
      emptyDir:
        medium: Memory
        sizeLimit: 8Gi
{%- endif %}
