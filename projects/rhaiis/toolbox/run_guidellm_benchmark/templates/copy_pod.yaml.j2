apiVersion: v1
kind: Pod
metadata:
  name: {{ ctx.copy_pod_name }}
  namespace: {{ args.namespace }}
  labels:
    app.kubernetes.io/managed-by: forge
    forge.openshift.io/project: rhaiis
spec:
  restartPolicy: Never
{%- if ctx.node_name %}
  nodeName: {{ ctx.node_name }}
{%- endif %}
  containers:
    - name: copy-helper
      image: {{ args.benchmark_image }}
      command: ["/bin/sleep", "300"]
      volumeMounts:
        - name: results
          mountPath: /results
  volumes:
    - name: results
      persistentVolumeClaim:
        claimName: {{ ctx.pvc_name }}
