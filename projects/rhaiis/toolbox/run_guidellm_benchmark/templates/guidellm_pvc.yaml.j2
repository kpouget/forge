apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ ctx.pvc_name }}
  namespace: {{ args.namespace }}
  labels:
    app.kubernetes.io/managed-by: forge
    forge.openshift.io/project: rhaiis
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: {{ args.pvc_size }}
